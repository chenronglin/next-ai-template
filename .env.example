# 本地开发默认使用仓库内 SQLite 文件，方便模板开箱即用。
DATABASE_URL="file:./dev.db"

# 生产环境请使用 `bunx @better-auth/cli secret` 生成新密钥。
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 配置后启用真实 AI streaming；不配置时保留本地演示流。
AI_GATEWAY_API_KEY=""

# 配置后使用 Resend 发送邮箱验证、重置密码和删除账户确认邮件；本地未配置时仅输出开发提示。
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# 配置对应 OAuth 应用后启用第三方登录按钮；未配置时按钮会展示为不可用状态。
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
